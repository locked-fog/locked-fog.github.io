---
import BaseLayout from '../layouts/BaseLayout.astro';

const profileFields = [
  ['公开称呼', 'Locked_Fog'],
  ['一句简介', 'ex-OIer，大学生，小众游戏哥，动漫婆罗门，天坑专业就读者，AI远视急先锋'],
  ['所在地区 / 时区', '中国 / UTC+8'],
  ['联系方式', 'Aboxyxy@outlook.com / 20243466@stu.cqu.edu.cn'],
  ['公开背景', '重庆大学环境与生态学院 2024 级本科生'],
];

const siteFacts = [
  ['视觉系统', 'AIRIS'],
  ['内容入口', 'Markdown + LaTeX'],
  ['站点框架', 'Astro'],
  ['发布方式', 'GitHub Pages'],
  ['开源协议', 'MIT License'],
];
---

<BaseLayout
  pageTitle="关于"
  pageDescription="关于 Locked_Fog，以及这个博客的写作方式、技术栈与维护原则。"
>
  <section class="about-grid">
    <article class="panel panel--classified-4 panel--bracket-tl panel--bracket-br prose-panel about-overview">
      <span class="micro-label micro-label--accent">ABOUT OPERATOR</span>
      <h2>关于我</h2>
      <p class="about-overview__lead">
        这里记录的是公开身份、个人背景与写作入口。它不追求完整履历，而是给第一次进入这个站点的人一个足够明确的认识。
      </p>

      <div class="prose">
        <p>
          我以 <strong>Locked_Fog</strong> 作为公开署名。曾经是 OI 竞赛参与者，现在是大学生，也长期关注小众游戏、
          动画与技术写作。这个博客主要承担“长期归档”的角色，所以比起即时表达，我更倾向于把内容整理成能反复阅读的文章。
        </p>

        <p>
          目前就读于 <strong>重庆大学环境与生态学院</strong>，英文表述为
          <strong> College of Environment and Ecology, Chongqing University</strong>。
          虽然专业本身未必天然贴近这里的全部内容，但也正因为这种错位，这个站点才更像是一个个人观察、学习与表达的稳定出口。
        </p>
      </div>
    </article>

    <aside class="panel panel--classified-2 about-side">
      <div class="section-header section-header--accent section-header--segmented">
        <span class="section-header__label">PROFILE</span>
        <span class="section-header__line"></span>
      </div>

      <ul class="status-list">
        {profileFields.map(([label, value]) => (
          <li>
            <span>{label}</span>
            <strong>{value}</strong>
          </li>
        ))}
      </ul>

      <div class="about-side__actions">
        <a class="btn btn--primary" href="https://github.com/locked-fog" target="_blank" rel="noreferrer">GitHub</a>
        <a class="btn btn--secondary" href="/">返回首页</a>
      </div>
    </aside>
  </section>

  <section class="content-stack">
    <article class="panel panel--classified-3 panel--bracket-tl panel--bracket-br prose-panel">
      <span class="micro-label">ABOUT THIS SITE</span>
      <h2>关于本页面</h2>
      <div class="prose">
        <p>
          这个博客是一个以 <strong>Markdown</strong> 为入口、以 <strong>LaTeX</strong> 为数学表达层、以
          <strong> GitHub Pages </strong>为发布目标的静态个人站点。它的目标不是做成信息流式的“新内容容器”，
          而是更偏向于一个长期可维护的个人知识归档界面。
        </p>

        <p>
          视觉上，这个页面继承了 AIRIS 的控制界面语言：克制的面板结构、分类条、材质纹理、以及较强的技术感。
          功能上，它优先服务于长文阅读、数学公式、代码展示和可追溯发布。
        </p>
      </div>

      <div class="section-header section-header--segmented">
        <span class="section-header__label">SITE STACK</span>
        <span class="section-header__line"></span>
      </div>

      <ul class="status-list">
        {siteFacts.map(([label, value]) => (
          <li>
            <span>{label}</span>
            <strong>{value}</strong>
          </li>
        ))}
      </ul>
    </article>
  </section>
</BaseLayout>
