---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostArchive from '../components/PostArchive.astro';
import { getVisibleSortedPosts, POSTS_PER_PAGE } from '../utils/posts';

const allPosts = await getCollection('posts');
const posts = getVisibleSortedPosts(allPosts, import.meta.env.PROD);
const featured = posts[0];
const pagePosts = posts.slice(0, POSTS_PER_PAGE);
const totalPages = Math.max(1, Math.ceil(posts.length / POSTS_PER_PAGE));
---

<BaseLayout pageTitle="首页">
  <section class="hero-grid">
    <article class="panel panel--classified-4 panel--bracket-tl panel--bracket-br hero-panel">
      <span class="micro-label micro-label--accent">最新文章</span>
      <h2>{featured ? featured.data.title : '写文章就够了，其余交给构建流程。'}</h2>
      <p>
        {featured
          ? featured.data.description
          : '这套博客已经接入 Markdown 内容流、LaTeX 公式渲染、AIRIS 风格阅读排版，以及 GitHub Pages 的自动发布工作流。'}
      </p>

      <div class="hero-panel__actions">
        {featured && <a class="btn btn--primary" href={`/posts/${featured.id}/`}>查看文章</a>}
        <a class="btn btn--secondary" href="/about/">查看写作方式</a>
      </div>
    </article>

    <aside class="panel panel--classified-3 hero-side">
      <div class="section-header section-header--accent section-header--segmented">
        <span class="section-header__label">STATUS</span>
        <span class="section-header__line"></span>
      </div>

      <ul class="status-list">
        <li>
          <span>VISUAL SYSTEM</span>
          <strong>AIRIS ACTIVE</strong>
        </li>
        <li>
          <span>CONTENT INPUT</span>
          <strong>MARKDOWN / LATEX</strong>
        </li>
        <li>
          <span>PUBLISH TARGET</span>
          <strong>GITHUB PAGES</strong>
        </li>
        <li>
          <span>ARCHIVE SIZE</span>
          <strong>{posts.length} POSTS</strong>
        </li>
      </ul>
    </aside>
  </section>

  <PostArchive posts={pagePosts} currentPage={1} totalPages={totalPages} />
</BaseLayout>
