---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout pageTitle="404">
  <section class="panel panel--classified-5 panel--bracket-tl panel--bracket-br hero-panel">
    <span class="micro-label micro-label--accent">ROUTE FAILURE</span>
    <h2>404 / SIGNAL NOT FOUND</h2>
    <p>这个地址不存在，或者对应的文章尚未部署。</p>
    <div class="hero-panel__actions">
      <a class="btn btn--secondary" href="/">返回首页</a>
    </div>
  </section>
</BaseLayout>
