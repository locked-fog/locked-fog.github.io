---
import type { CollectionEntry } from 'astro:content';
import ClassificationBar from './ClassificationBar.astro';
import { formatDate } from '../utils/date';
import { getPageHref } from '../utils/posts';

interface Props {
  posts: CollectionEntry<'posts'>[];
  currentPage: number;
  totalPages: number;
}

const { posts, currentPage, totalPages } = Astro.props;

const previousHref = currentPage > 1 ? getPageHref(currentPage - 1) : null;
const nextHref = currentPage < totalPages ? getPageHref(currentPage + 1) : null;
const pages = Array.from({ length: totalPages }, (_, index) => index + 1);
---

<section class="panel panel--classified-2 panel--bracket-tl archive-panel">
  <div class="section-header section-header--segmented section-header--accent">
    <span class="section-header__label">ARCHIVE</span>
    <span class="section-header__line"></span>
  </div>

  <div class="post-list">
    {posts.map((post) => (
      <article class={`post-card panel panel--classified-${post.data.classification}`}>
        <div class="post-card__meta">
          <ClassificationBar level={post.data.classification as 1 | 2 | 3 | 4 | 5} horizontal size="sm" />
          <span>{formatDate(post.data.pubDate)}</span>
        </div>

        <h3><a href={`/posts/${post.id}/`}>{post.data.title}</a></h3>
        <p>{post.data.description}</p>

        <div class="post-card__footer">
          <ul class="tag-list" aria-label="标签">
            {post.data.tags.map((tag) => <li>{tag}</li>)}
          </ul>
          <a href={`/posts/${post.id}/`} class="post-card__link">READ ENTRY</a>
        </div>
      </article>
    ))}
  </div>

  {totalPages > 1 && (
    <nav class="pagination" aria-label="文章分页">
      {previousHref ? (
        <a class="btn btn--secondary btn--sm" href={previousHref}>上一页</a>
      ) : (
        <span class="btn btn--secondary btn--sm pagination__button pagination__button--disabled" aria-disabled="true">上一页</span>
      )}

      <div class="pagination__pages">
        {pages.map((page) => {
          const href = getPageHref(page);
          const isCurrent = page === currentPage;

          return isCurrent ? (
            <span class="pagination__page pagination__page--current" aria-current="page">{page}</span>
          ) : (
            <a class="pagination__page" href={href}>{page}</a>
          );
        })}
      </div>

      {nextHref ? (
        <a class="btn btn--secondary btn--sm" href={nextHref}>下一页</a>
      ) : (
        <span class="btn btn--secondary btn--sm pagination__button pagination__button--disabled" aria-disabled="true">下一页</span>
      )}
    </nav>
  )}
</section>
